DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
PUBLIC_APP_URL=https://your-backend.onrender.com
FRONTEND_APP_URL=https://your-frontend.vercel.app
DJANGO_ALLOWED_HOSTS=your-backend.onrender.com,127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:8080,http://127.0.0.1:8080
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app,https://your-backend.onrender.com
DJANGO_SESSION_COOKIE_SAMESITE=None
DJANGO_CSRF_COOKIE_SAMESITE=None
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
# Local dev only (leave unset in production)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
